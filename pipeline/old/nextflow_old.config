// General DAP-seq pipeline
workDir = "/mnt/ada/projects/spruce/nstreet/spruce_chromatin_dynamics/DAP-seq_test/nf_workdir"

params {
  // Input/output
  input = "/mnt/picea/home/tkalman/Git/DAP-seq_processing/samplesheet_aspen_short.csv"
  outdir      = "/mnt/ada/projects/spruce/nstreet/spruce_chromatin_dynamics/DAPseq_test/nf_out"

  // Role labels used in samplesheet
  tf_role    = 'tf'
  input_role = 'input'

  // Reference files
  bowtie2_index = "/mnt/reference/Populus-tremula/v2.2/indices/bowtie2/index"
  genome_fasta  = "/mnt/reference/Populus-tremula/v2.2/fasta/Potra02_genome.fasta"
  genome_fai    = "/mnt/reference/Populus-tremula/v2.2/fasta/Potra02_genome.fasta.fai"
  promoter_bed  = "/mnt/picea/home/tkalman/FOR-ANALYSIS-IN-ALL-PHD-PROJECTS/genomic_annotations/Ptremula_annotations/promoters_calculated_from_TSS.bedtools_slop_-l2000_-r50_-s.sorted.bed"
  motif_db      = "/mnt/picea/home/tkalman/FOR-ANALYSIS-IN-ALL-PHD-PROJECTS/PlantTFDB/Ath_TF_binding_motifs.meme"

  // Program arguments
  singularity_bind        = '--bind /mnt/ada:/mnt/ada --bind /mnt/picea:/mnt/picea'
  fastqc_args             = '--noextract'
  trimmomatic_args        = '-phred33 ILLUMINACLIP:/mnt/picea/home/tkalman/Git/DAP-seq_processing/TruSeq3-PE-2.fa:2:30:10:2:TRUE SLIDINGWINDOW:5:20 MINLEN:50'
  bowtie2_args            = '--very-sensitive --end-to-end --dovetail --minins 50 --maxins 1000'
  samtools_index_args     = ''
  samtools_filter_args    = '-h -b -f 3 -F 12 -q 20'
  samtools_collate_args   = '--verbosity 3'
  samtools_fixmate_args   = '-m'
  samtools_markdup_args   = '-S -s -r'
  macs3_args              = '-g 381973357 --keep-dup all -f BAMPE'
  bedtools_intersect_args = '-wo'
  meme_args               = '-meme-mod anr'

  // Pipeline settings
  n_top_peaks             = 5000
  meme_slop_bp            = 250

  // Singularity images
  fastqc_sif      = "/mnt/picea/home/tkalman/singularity/fastqc_0.11.9.sif"
  multiqc_sif     = "/mnt/picea/home/tkalman/singularity/multiqc_1.11.sif"
  trimmomatic_sif = "/mnt/picea/home/tkalman/singularity/trimmomatic_0.39.sif"
  bowtie2_sif     = "/mnt/picea/home/tkalman/singularity/bowtie2_2.4.5.sif"
  samtools_sif    = "/mnt/picea/home/tkalman/singularity/samtools_1.16.sif"
  macs3_sif       = "/mnt/picea/home/tkalman/singularity/macs3_v3.0.0b3.sif"
  bedtools_sif    = "/mnt/picea/home/tkalman/singularity/bedtools_2.30.0.sif"
  meme_sif        = "/mnt/picea/home/tkalman/singularity/memesuite_5.5.2.sif"
}

singularity {
  enabled    = true
  autoMounts = true
}

process {
  executor = 'slurm'
  clusterOptions = '--account=u2021028 -p main --mail-user=teitur.ahlgren.kalman@umu.se --mail-type=BEGIN,END,FAIL'
  scratch = false
}

executor {
  pollInterval = '30 s'
  exitReadTimeout = '12 h'
}

profiles {
  slurm {
    process {
      queue = 'batch'
      errorStrategy = 'terminate'

      withName: 'FASTQC_RAW|FASTQC_TRIMMED' {
        cpus = 2
        memory = '16 GB'
        time = '4h'
      }

      withName: 'MULTIQC_RAW|MULTIQC_TRIMMED' {
        cpus = 1
        memory = '8 GB'
        time = '2h'
      }

      withName: 'TRIMMOMATIC_PE' {
        cpus = 18
        memory = '64 GB'
        time = '1d'
      }

      withName: 'BOWTIE2_ALIGN_SORT' {
        cpus = 18
        memory = '100 GB'
        time = '1d'
      }

      withName: 'SAMTOOLS_FILTER_Q20|SAMTOOLS_MARKDUP_REMOVE' {
        cpus = 18
        memory = '100 GB'
        time = '1d'
      }

      withName: 'MACS3_CALLPEAK' {
        cpus = 4
        memory = '64 GB'
        time = '12h'
      }

      withName: 'FRIP_CALCULATION' {
        cpus = 1
        memory = '64 GB'
        time = '2h'
      }

      withName: 'PEAK_PROMOTER_INTERSECT' {
        cpus = 1
        memory = '16 GB'
        time = '1h'
      }

      withName: 'TOP_SIGNAL_PEAKS' {
        cpus = 1
        memory = '16 GB'
        time = '4h'
      }

      withName: 'MEME_CHIP' {
        cpus = 8
        memory = '128 GB'
        time = '3d'
      }

      withName: 'COLLECT_SAMPLE_STATS' {
        cpus = 1
        memory = '4 GB'
        time = '1h'
      }
    }
  }
}
