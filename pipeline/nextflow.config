// General DAP-seq pipeline
workDir = "$HOME/storage2/DAPseq_test/nf_workdir3"

params {
  // Input/output
  input = "$HOME/Git/DAP-seq_processing/samplesheet.csv"
  outdir      = "$HOME/storage2/DAPseq_test/nf_out3"

  // Role labels used in samplesheet
  tf_role    = 'tf'
  input_role = 'input'

  // Reference files
  bowtie2_index = "$HOME/storage2/fasta_w-MT-and-CP/original/bowtie2/Picab02_chromosomes_and_unplaced"
  genome_fasta  = "$HOME/storage2/fasta_w-MT-and-CP/original/pabies-2.0_chromosomes_and_unplaced.fa"
  genome_fai    = "$HOME/storage2/fasta_w-MT-and-CP/original/pabies-2.0_chromosomes_and_unplaced.fa.fai"
  promoter_bed  = "$HOME/storage2/Pabies_annotation/Picab02_230926_at01_longest_no_TE_sorted.only_PASA_PASN.2kb_upstream_50bp_downstream_TSS.bed"
  motif_db      = "$HOME/storage2/PlantTFDB/Ath_TF_binding_motifs.meme"
  // Program arguments
  fastqc_args             = '--noextract'
  trimmomatic_args        = '-phred33 ILLUMINACLIP:$HOME/Git/microC_spruce-genome-project/TruSeq3-PE-2.fa:2:30:10:2:TRUE SLIDINGWINDOW:5:20 MINLEN:50'
  bowtie2_args            = '--very-sensitive --end-to-end --dovetail --minins 50 --maxins 1000'
  samtools_filter_args    = '-h -b -f 3 -F 12 -q 20'
  samtools_collate_args   = '--verbosity 3'
  samtools_fixmate_args   = '-m'
  samtools_markdup_args   = '-S -s -r'
  macs3_args              = '-g 14150000000 --keep-dup all -f BAMPE'
  bedtools_intersect_args = '-wo'
  meme_args               = '-meme-mod anr'

  // Pipeline settings
  n_top_peaks             = 5000
  meme_slop_bp            = 250

  // Singularity images
  fastqc_sif      = "$HOME/storage2/singularity/fastqc_0.11.9.sif"
  multiqc_sif     = "$HOME/storage2/singularity/multiqc_1.11.sif"
  trimmomatic_sif = "$HOME/storage2/singularity/trimmomatic_0.39.sif"
  bowtie2_sif     = "$HOME/storage2/singularity/bowtie2_2.4.5.sif"
  samtools_sif    = "$HOME/storage2/singularity/samtools_1.16.sif"
  macs3_sif       = "$HOME/storage2/singularity/macs3_v3.0.0b3.sif"
  bedtools_sif    = "$HOME/storage2/singularity/bedtools_2.30.0.sif"
  meme_sif        = "$HOME/storage2/singularity/memesuite_5.5.2.sif"
}

singularity {
  enabled    = true
  autoMounts = true
}

process {
  executor = 'slurm'
  clusterOptions = '--account=hpc2n2025-143 --mail-user=teitur.ahlgren.kalman@umu.se --mail-type=BEGIN,END,FAIL'
  scratch = false
}

executor {
  pollInterval = '30 s'
  exitReadTimeout = '12 h'
}

profiles {
  slurm {
    process {
      queue = 'batch'
      errorStrategy = 'terminate'

      withName: 'FASTQC_RAW|FASTQC_TRIMMED' {
        cpus = 2
        memory = '16 GB'
        time = '4h'
      }

      withName: 'MULTIQC_RAW|MULTIQC_TRIMMED' {
        cpus = 1
        memory = '8 GB'
        time = '2h'
      }

      withName: 'TRIMMOMATIC_PE' {
        cpus = 18
        memory = '64 GB'
        time = '1d'
      }

      withName: 'BOWTIE2_ALIGN_SORT' {
        cpus = 18
        memory = '256 GB'
        time = '3d'
      }

      withName: 'SAMTOOLS_FILTER_Q20|SAMTOOLS_MARKDUP_REMOVE' {
        cpus = 18
        memory = '128 GB'
        time = '2d'
      }

      withName: 'MACS3_CALLPEAK' {
        cpus = 4
        memory = '64 GB'
        time = '12h'
      }

      withName: 'FRIP_CALCULATION' {
        cpus = 1
        memory = '64 GB'
        time = '2h'
      }

      withName: 'PEAK_PROMOTER_INTERSECT' {
        cpus = 1
        memory = '16 GB'
        time = '1h'
      }

      withName: 'TOP_SIGNAL_PEAKS' {
        cpus = 1
        memory = '16 GB'
        time = '4h'
      }

      withName: 'MEME_CHIP' {
        cpus = 8
        memory = '128 GB'
        time = '3d'
      }

      withName: 'COLLECT_SAMPLE_STATS' {
        cpus = 1
        memory = '4 GB'
        time = '1h'
      }
    }
  }
}
